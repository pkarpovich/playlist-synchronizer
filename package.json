{
  "name": "playlist-synchronizer",
  "version": "1.5.0",
  "description": "The app allows to sync playlists between music services",
  "type": "module",
  "exports": "./src/index.ts",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "build": "tsc",
    "format": "prettier 'src/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts'",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint --fix 'src/**/*.ts'",
    "check-types": "tsc --noemit",
    "test": "tsx --test 'src/**/*.test.ts'",
    "prepare": "husky || true"
  },
  "keywords": [
    "yandex",
    "yandex-music",
    "spotify",
    "synchronizer"
  ],
  "author": "Pavel Karpovich <pavel.karpovich@outlook.com>",
  "license": "MIT",
  "devDependencies": {
    "@tsconfig/node24": "^24.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24",
    "@types/signale": "^1.4.4",
    "@types/spotify-web-api-node": "^5.0.7",
    "@typescript-eslint/eslint-plugin": "^5.55.0",
    "@typescript-eslint/parser": "^5.55.0",
    "eslint": "^8.36.0",
    "eslint-config-prettier": "^8.7.0",
    "eslint-import-resolver-typescript": "^3.5.3",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.6.2",
    "tsx": "^4.22",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "awilix": "^13.0.5",
    "croner": "^10.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fetch-socks": "^1.3.3",
    "helmet": "^8.2",
    "lowdb": "^7.0.1",
    "signale": "^1.4.0",
    "spotify-web-api-node": "^5.0.2",
    "yup": "^1.7"
  },
  "peerDependencies": {
    "eslint-plugin-import": ">=2.25.3 <3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "ssh://git@github.com:pkarpovich/playlist-synchronizer.git"
  },
  "pnpm": {
    "overrides": {
      "axios@<0.21.1": ">=0.21.1",
      "follow-redirects@<1.14.8": ">=1.14.8",
      "follow-redirects@<1.14.7": ">=1.14.7",
      "axios@<0.21.2": ">=0.21.2",
      "undici": "^7.0.0"
    }
  }
}
