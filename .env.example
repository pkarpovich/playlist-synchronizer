HTTP_PORT=3200
DB_PATH=./db/db.json
SYNC_CONFIG_PATH=./sync-config.json

JOB_CRON_TIME=@hourly

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=

# Yandex Music source is fetched over a SOCKS5 proxy that egresses from a
# RU/CIS box (api.music.yandex.net is geo-blocked elsewhere). Leave empty to
# fetch directly. Example: socks5h://<host>:<port>
YANDEX_API_PROXY=
# Optional override; defaults to https://api.music.yandex.net when unset.
YANDEX_API_BASE_URL=

# Best-effort sync notifications. When NOTIFY_URL is set, each run with
# something notable (additions, failures, or empty sources) posts a Markdown
# status card to a tg-relay /send endpoint; unchanged runs stay silent. Leave
# empty to disable. Example: https://relay.pkarpovich.space/send
NOTIFY_URL=
# X-Secret header sent with the notification POST (only used when NOTIFY_URL set).
NOTIFY_SECRET=
